# ── Database (Supabase Postgres) ────────────────────────────────
# Use the Supavisor pooler URLs (IPv4). Dashboard → Connect → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:5432/postgres"

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET="a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seed admin account (used by prisma/seed.js)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# ── Supabase Storage (for image uploads) ────────────────────────
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="media"

# ── Server ──────────────────────────────────────────────────────
PORT=4000
