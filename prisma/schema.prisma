generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("ADMIN") // "ADMIN" | "TECHNICAL_ADMIN"
  superKey     String?  // extra secret for tech ops
  createdAt    DateTime @default(now())
}


/// Flexible key/JSON store for grouped content: "hero", "about", "contact", "marquee".
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Service {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  icon      String   @default("FiPenTool")
  title     String
  about     String
  createdAt DateTime @default(now())
}

model ProcessStep {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  step      String
  icon      String   @default("FiSearch")
  title     String
  about     String
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  order       Int      @default(0)
  slug        String?
  title       String
  tag         String
  imageUrl    String
  wide        Boolean  @default(false)
  // Detail-page content
  description String?
  year        String?
  location    String?
  area        String?
  beforeUrl   String?
  afterUrl    String?
  gallery     Json?
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  name      String
  post      String
  quote     String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  slug      String   @unique
  title     String
  excerpt   String
  content   String   // Can hold markdown, text or simple HTML
  imageUrl  String
  category  String
  author    String   @default("HAVI'S DESIGN")
  readTime  String   @default("5 min read")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdPost {
  id           String   @id @default(cuid())
  order        Int      @default(0)
  title        String
  type         String   // E.g., "Material Supply", "Machinery Rental", etc.
  description  String
  price        String?  // E.g., "Negotiable", "ETB 15,000/day"
  location     String   @default("Addis Ababa")
  contactPhone String
  contactEmail String?
  imageUrl     String
  features     Json?    // Array of key specifications/highlights
  approved     Boolean  @default(true)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Booking System ─────────────────────────────────────────────────────────

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String   // "Interior Design" | "Renovation" | "Consultation" | "Other"
  date      DateTime
  timeSlot  String   // e.g. "09:00"
  message   String?
  status    String   @default("pending") // pending | confirmed | cancelled | completed
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── AI Chatbot ─────────────────────────────────────────────────────────────

model ChatSession {
  id        String        @id @default(cuid())
  sessionId String        @unique
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(cuid())
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sessionId String
  role      String      // "user" | "assistant"
  content   String
  createdAt DateTime    @default(now())
}

// ── Admin Notifications ────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String   // "booking" | "message" | "chat"
  title     String
  body      String
  read      Boolean  @default(false)
  refId     String?
  createdAt DateTime @default(now())
}

// ── Technical Admin: AI Logging ───────────────────────────────────

model AiLog {
  id         String   @id @default(cuid())
  provider   String   // "openrouter" | "gemini" | "static"
  model      String
  prompt     String
  response   String?
  tokens     Int?
  latencyMs  Int?
  success    Boolean  @default(true)
  errorMsg   String?
  sessionId  String?
  createdAt  DateTime @default(now())
}

// ── Technical Admin: Error Logging ────────────────────────────────

model ErrorLog {
  id         String    @id @default(cuid())
  severity   String    @default("ERROR") // "DEBUG" | "INFO" | "WARN" | "ERROR" | "FATAL"
  route      String?
  method     String?
  message    String
  stack      String?
  meta       Json?
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

// ── Technical Admin: Report Jobs ─────────────────────────────────

model ReportJob {
  id          String   @id @default(cuid())
  type        String   // "ai-usage" | "errors" | "bookings" | "chat" | "full"
  params      Json?
  result      Json?
  generatedAt DateTime @default(now())
}
